# ---------------------------------------------------------------
# krypt-agent tennis — gitignore
# ---------------------------------------------------------------

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Virtual environments
venv/
env/
.venv/
.env.local

# Secrets
.env
*.key
*_secret*
*_credentials*

# Logs (runtime output — Railway volume handles these, not git)
*.log
*.log.*

# Backup files (kept locally, not shipped)
*.bak
*.bak_*
*.pre_*.bak

# Analysis scratch files (ad-hoc investigations, not production code)
_*.py
_*.ps1
_*.csv
_*.txt
_placeholder.txt
# NOTE: _elo_snapshot.json is production data — explicitly un-ignored below
_*.json
!_elo_snapshot.json

# Old runner versions (kept on laptop for reference only)
tennis_multi_v6.py
tennis_multi_v7.py
tennis_multi_v8.py
tennis_multi_fork.py
tennis_multi.py
tennis_multi.py.*

# Old detector/strategy backups
tennis_*.bak*

