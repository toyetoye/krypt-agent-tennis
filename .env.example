# krypt-agent tennis — environment variables template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# On Railway, set these in the project "Variables" tab instead of using a file.

# Required: api-tennis.com API key
APITENNIS_KEY=your_api_tennis_key_here

# Optional: Redis URL for the prior filter. Leave unset to disable.
# REDIS_URL=redis://localhost:6379/0

# Recommended on Windows (no-op elsewhere)
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
